---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { education } from "@/data/evidence";
---

<BaseLayout title="التعليم والشهادات" description="المؤهلات الأكاديمية والدورات المهنية الموثقة في قاعدة المعرفة المهنية.">
  <PageHero eyebrow="التعليم" title="أساس أكاديمي يجمع الإحصاء وعلوم الحاسوب" description="هذا الجمع بين البيانات والحوسبة شكّل طريقة التعامل مع الأنظمة المعقدة وبناء المنتجات القابلة للقياس." />
  <section class="container-pad py-14">
    <div class="grid gap-5 md:grid-cols-3">
      {education.map((item) => (
        <article class="surface rounded-lg p-5">
          <p class="text-sm font-semibold text-copper dark:text-amber-300">{item.date}</p>
          <h2 class="mt-2 text-xl font-bold">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{item.institution}</p>
          <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{item.meta}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
