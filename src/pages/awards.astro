---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { awards, recommendations } from "@/data/evidence";
---

<BaseLayout title="الجوائز والتوصيات" description="الأدلة المهنية الرسمية: جوائز، شهادات خدمة، وتوصيات مرتبطة بمشاريع وجهات.">
  <PageHero eyebrow="الأدلة" title="الثقة المهنية تعرض عبر وثائق وأثر" description="الجوائز والتوصيات ليست زخرفة، بل أدلة مرتبطة بمشاريع وجهات وسنوات." />
  <section class="container-pad grid gap-10 py-14 lg:grid-cols-2">
    <div>
      <h2 class="text-2xl font-bold">الجوائز</h2>
      <div class="mt-5 grid gap-4">
        {awards.map((award) => (
          <article class="surface rounded-lg p-5">
            <p class="text-sm font-semibold text-copper dark:text-amber-300">{award.year}</p>
            <h3 class="mt-2 text-xl font-bold">{award.title}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{award.organization}</p>
            <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">المشروع: {award.project}</p>
          </article>
        ))}
      </div>
    </div>
    <div>
      <h2 class="text-2xl font-bold">التوصيات والشهادات</h2>
      <div class="mt-5 grid gap-4">
        {recommendations.map((rec) => (
          <article class="surface rounded-lg p-5">
            <p class="text-sm font-semibold text-teal dark:text-teal-300">{rec.date}</p>
            <h3 class="mt-2 text-xl font-bold">{rec.title}</h3>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{rec.organization} - {rec.author}</p>
            <p class="mt-3 text-sm leading-7 text-slate-700 dark:text-slate-200">{rec.evidence}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
