---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import MetricGrid from "@/components/MetricGrid.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import Timeline from "@/components/Timeline.astro";
import { ArrowLeft, Download, Mail } from "lucide-astro";
import { executiveScale, site, principles } from "@/data/site";
import { projects } from "@/data/projects";
import { awards, recommendations } from "@/data/evidence";
---

<BaseLayout title={site.name} description={site.description}>
  <section class="relative overflow-hidden bg-white py-16 dark:bg-slate-900 sm:py-20">
    <div class="container-pad grid items-center gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <div>
        <p class="eyebrow">{site.role}</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-slate-950 sm:text-6xl dark:text-white">{site.name}</h1>
        <p class="mt-4 text-2xl font-semibold text-copper dark:text-amber-300">{site.tagline}</p>
        <p class="mt-6 max-w-3xl text-lg leading-9 text-slate-700 dark:text-slate-200">{site.heroStatement}</p>
        <p class="mt-5 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300">{site.description}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/projects" class="inline-flex items-center gap-2 rounded-md bg-slate-950 px-5 py-3 text-sm font-bold text-white dark:bg-white dark:text-slate-950">
            عرض المشاريع
            <ArrowLeft class="h-4 w-4" aria-hidden="true" />
          </a>
          <a href={site.resumePdf} class="inline-flex items-center gap-2 rounded-md border border-slate-300 px-5 py-3 text-sm font-bold text-slate-800 dark:border-slate-700 dark:text-slate-100">
            تحميل السيرة
            <Download class="h-4 w-4" aria-hidden="true" />
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-md border border-slate-300 px-5 py-3 text-sm font-bold text-slate-800 dark:border-slate-700 dark:text-slate-100">
            تواصل معي
            <Mail class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>
      </div>
      <aside class="surface rounded-lg p-5">
        <img src="/images/bakrialtaif.jpg" alt="أبوبكر عبد الباقي الطائف أحمد" class="aspect-[4/3] w-full rounded-lg object-cover object-top" loading="eager" />
        <p class="mt-5 text-sm font-semibold text-slate-500 dark:text-slate-400">مؤشر الثقة التنفيذي</p>
        <div class="mt-4 grid gap-3">
          {principles.map((principle) => (
            <div class="rounded-lg bg-slate-50 p-4 text-sm leading-7 text-slate-700 dark:bg-slate-800 dark:text-slate-200">{principle}</div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="py-14">
    <div class="container-pad">
      <SectionTitle eyebrow="الأثر والحجم" title="أرقام تعكس حجم الأنظمة لا مجرد سنوات خبرة" description="هذه المؤشرات مرتبطة بمشاريع ومنصات فعلية، وتساعد الزائر على فهم حجم التشغيل والانتشار والأثر." />
      <div class="mt-8"><MetricGrid /></div>
      <div class="mt-6 flex flex-wrap gap-2">
        {executiveScale.map((item) => <span class="rounded-md border border-slate-200 bg-white px-3 py-1.5 text-sm font-bold text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-200">{item}</span>)}
      </div>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="container-pad">
      <SectionTitle eyebrow="المشاريع الرئيسية" title="المشاريع الرئيسية" description="بطاقات مستقلة للمشاريع الوطنية والمؤسسية الكبيرة، تعرض الدور والتقنيات والخصائص والأثر المؤسسي بصورة ثابتة." />
      <div class="mt-8 grid gap-5 lg:grid-cols-2">
        {projects.filter((project) => project.featured).map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="py-14">
    <div class="container-pad grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <SectionTitle eyebrow="الرحلة المهنية" title="من العمل التقني والأكاديمي إلى المنصات الحكومية" description="تراكمت الخبرة عبر التعليم، التدريب، الصناعة، القطاع الخاص، ووزارة الداخلية ووزارة الاتصالات والتحول الرقمي." />
      </div>
      <Timeline />
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="container-pad grid gap-8 lg:grid-cols-2">
      <div>
        <SectionTitle eyebrow="جوائز" title="اعتراف مهني مرتبط بمشاريع" />
        <div class="mt-6 grid gap-3">
          {awards.slice(0, 2).map((award) => (
            <div class="surface rounded-lg p-5">
              <p class="font-bold">{award.title} - {award.year}</p>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{award.project}</p>
              <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{award.description}</p>
            </div>
          ))}
        </div>
      </div>
      <div>
        <SectionTitle eyebrow="توصيات" title="ثقة مهنية موثقة" />
        <div class="mt-6 grid gap-3">
          {recommendations.slice(0, 2).map((rec) => (
            <div class="surface rounded-lg p-5">
              <p class="font-bold">{rec.organization}</p>
              <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{rec.evidence}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
