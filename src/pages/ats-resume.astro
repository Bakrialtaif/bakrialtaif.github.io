---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { site, impactMetrics } from "@/data/site";
import { experience } from "@/data/experience";
import { projects } from "@/data/projects";
---

<BaseLayout title="نسخة ATS" description="نسخة نصية منظمة من السيرة الذاتية لأبوبكر الطائف مهيأة لأنظمة تتبع المتقدمين.">
  <PageHero eyebrow="نسخة ATS" title={site.name} description={`${site.role} - ${site.description}`} />
  <section class="container-pad grid gap-10 py-14">
    <section>
      <h2 class="text-2xl font-bold">الأثر</h2>
      <ul class="mt-4 grid gap-2 leading-8">
        {impactMetrics.map((metric) => <li>{metric.value}: {metric.label}</li>)}
      </ul>
    </section>
    <section>
      <h2 class="text-2xl font-bold">الخبرة</h2>
      <div class="mt-4 grid gap-5">
        {experience.map((item) => (
          <article>
            <h3 class="font-bold">{item.title} - {item.organization}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">{item.period} | {item.country}</p>
            <ul class="mt-2 grid gap-1 text-sm leading-7">
              {item.responsibilities.map((r) => <li>{r}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>
    <section>
      <h2 class="text-2xl font-bold">مشاريع مختارة</h2>
      <div class="mt-4 grid gap-5">
        {projects.map((project) => (
          <article>
            <h3 class="font-bold">{project.name}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">{project.organization} | {project.role}</p>
            <p class="mt-2 text-sm leading-7">{project.summary}</p>
          </article>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
