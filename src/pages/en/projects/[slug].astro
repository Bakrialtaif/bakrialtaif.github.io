---
import ProjectCaseStudyScreen from "@/screens/ProjectCaseStudyScreen.astro";
import { enAwards } from "@/data/awards/en";
import { enRecommendations } from "@/data/recommendations/en";
import { getProjectCaseStudies, getProjectCaseStudy } from "@/data/project-case-studies";

export function getStaticPaths() {
  return getProjectCaseStudies("en").map((project) => ({
    params: { slug: project.slug },
  }));
}

const locale = "en";
const { slug } = Astro.params;
const project = getProjectCaseStudy(locale, slug ?? "");
if (!project) {
  return Astro.redirect("/en/projects/");
}

const awardEvidence = enAwards
  .filter((award) => project.relatedAwardProjects.includes(award.project))
  .map((award) => ({ title: award.title, description: award.description, href: award.image }));
const recommendationEvidence = enRecommendations
  .filter((recommendation) => project.relatedRecommendationOrganizations.includes(recommendation.organization))
  .map((recommendation) => ({ title: recommendation.title, description: recommendation.evidence }));
const evidence = [...awardEvidence, ...recommendationEvidence];
---

<ProjectCaseStudyScreen locale={locale} project={project} evidence={evidence} />
