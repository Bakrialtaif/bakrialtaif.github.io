---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { projects } from "@/data/projects";
---

<BaseLayout title="أبرز المشاريع" description="دراسات حالة لمشاريع حكومية ومؤسسية موثقة بالأدوار والنتائج والأرقام.">
  <PageHero eyebrow="أبرز المشاريع" title="مشاريع وطنية ومؤسسية موثقة بالأثر" description="كل بطاقة تعرض اسم المشروع، الجهة، الفترة، النبذة، الدور، أبرز التقنيات، والأثر بصيغة موحدة." />
  <section class="container-pad py-14">
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
