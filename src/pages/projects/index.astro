---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { projects } from "@/data/projects";
---

<BaseLayout title="المشاريع ودراسات الحالة" description="دراسات حالة لمشاريع حكومية ومؤسسية موثقة بالأدوار والنتائج والأرقام.">
  <PageHero eyebrow="المشاريع" title="المشروع هنا دليل مهني، لا مجرد عنوان في سيرة ذاتية" description="تُعرض المشاريع حسب القدرة التي تثبتها: التكامل، الأتمتة، الخدمات الإلكترونية، إدارة البيانات، وبناء الفرق." />
  <section class="container-pad py-14">
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
