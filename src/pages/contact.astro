---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { Download, Github, Linkedin, Mail, MapPin, Phone, Globe } from "lucide-astro";
import { availableFor, site } from "@/data/site";

const contacts = [
  { label: "البريد الإلكتروني", value: site.email, href: `mailto:${site.email}`, icon: Mail },
  ...(site.phone ? [{ label: "الهاتف", value: site.phone, href: `tel:${site.phone}`, icon: Phone }] : []),
  { label: "LinkedIn", value: "الملف المهني", href: site.linkedin, icon: Linkedin },
  { label: "GitHub", value: "bakrialtaif", href: site.github, icon: Github },
  { label: "الموقع", value: site.website, href: site.website, icon: Globe },
  { label: "الموقع الحالي", value: site.location, href: undefined, icon: MapPin }
];
---

<BaseLayout title="التواصل" description="قنوات التواصل المباشرة مع أبوبكر الطائف وملفات السيرة الذاتية.">
  <PageHero eyebrow="التواصل" title="للمشاريع التي تحتاج قيادة تقنية أو معمارية مؤسسية أو تحولًا رقميًا قابلًا للقياس" description="إذا كنت تبحث عن قائد تقني، مهندس أنظمة مؤسسية، أو مستشار تحول رقمي، يسعدني مناقشة كيف يمكن أن أساهم في تحويل التحدي الحالي إلى منتج أو منصة قابلة للتنفيذ." />
  <section class="container-pad py-14">
    <div class="mb-10">
      <h2 class="text-2xl font-bold">Available For</h2>
      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {availableFor.map((item) => (
          <div class="surface rounded-lg p-4 text-sm font-bold text-slate-800 dark:text-slate-100">{item}</div>
        ))}
      </div>
    </div>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {contacts.map(({ label, value, href, icon: Icon }) => (
        <article class="surface rounded-lg p-5">
          <Icon class="h-5 w-5 text-teal dark:text-teal-300" aria-hidden="true" />
          <h2 class="mt-3 text-lg font-bold">{label}</h2>
          {href ? <a class="mt-2 block text-sm text-river dark:text-blue-300" href={href}>{value}</a> : <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{value}</p>}
        </article>
      ))}
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={site.resumePdf} class="inline-flex items-center gap-2 rounded-md bg-slate-950 px-5 py-3 text-sm font-bold text-white dark:bg-white dark:text-slate-950"><Download class="h-4 w-4" />تحميل السيرة PDF</a>
      <a href="/ats-resume" class="inline-flex items-center gap-2 rounded-md border border-slate-300 px-5 py-3 text-sm font-bold dark:border-slate-700">عرض نسخة ATS</a>
    </div>
  </section>
</BaseLayout>
