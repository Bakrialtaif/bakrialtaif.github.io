---
import { Facebook, Globe2, Linkedin, Mail, MessageCircle, Phone } from "lucide-astro";
import { aboutProfile } from "@/i18n/aboutProfile";
import type { Locale } from "@/i18n";

type Props = { locale?: Locale };
const { locale = "ar" } = Astro.props;
const profile = aboutProfile[locale];

const contactIcons = {
  email: Mail,
  whatsapp: MessageCircle,
  phone: Phone,
  linkedin: Linkedin,
  website: Globe2,
  facebook: Facebook,
};

const primaryContactCards = profile.contactCards.filter((card) => ["whatsapp", "email", "linkedin"].includes(card.id));
---

<section id="contact" class="scroll-mt-20 bg-slate-950 py-16 text-white dark:bg-black" data-analytics-section="contact" data-analytics-view-event="contact_section_view">
  <div class="container-pad">
    <p class="eyebrow text-teal-300">{profile.contactEyebrow}</p>
    <h2 class="mt-2 max-w-3xl text-3xl font-bold leading-tight sm:text-4xl">{profile.contactTitle}</h2>
    <p class="mt-5 max-w-3xl text-lg leading-9 text-slate-100">{profile.contactText}</p>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {primaryContactCards.map((card) => {
        const Icon = contactIcons[card.id];

        return (
          <a href={card.href} target={card.external ? "_blank" : undefined} rel={card.external ? "noopener noreferrer" : undefined} class="flex min-w-0 items-start gap-3 rounded-lg border border-white/10 p-4 transition hover:bg-white/5" data-analytics-event={`${card.id}_click`} data-analytics-location="contact_section">
            <Icon class="mt-1 h-4 w-4 shrink-0 text-teal-300" aria-hidden="true" />
            <span class="min-w-0">
              <span class="block text-xs font-bold text-slate-400">{card.label}</span>
              <span class="mt-1 block break-words font-latin text-base font-bold text-white hover:text-teal-200" dir="ltr">{card.value}</span>
            </span>
          </a>
        );
      })}
    </div>
  </div>
</section>
