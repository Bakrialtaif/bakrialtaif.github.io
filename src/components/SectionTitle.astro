---
type Props = { eyebrow?: string; title: string; description?: string };
const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-2 text-3xl font-bold leading-tight text-slate-950 sm:text-4xl dark:text-white">{title}</h2>
  {description && <p class="mt-4 text-base leading-8 text-slate-600 dark:text-slate-300">{description}</p>}
</div>
