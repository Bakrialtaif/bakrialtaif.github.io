---
import { getContent, type Locale } from "@/i18n";
type Props = { locale?: Locale };
const { locale = "ar" } = Astro.props;
const { site, navigation } = getContent(locale);
const socialLinks = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/bakrialtaif/" },
  { label: "GitHub", href: site.github },
  { label: "Facebook", href: "https://web.facebook.com/bakrialtaif" },
  { label: locale === "ar" ? "الخصوصية" : "Privacy", href: locale === "ar" ? "/privacy" : "/en/privacy" },
];
---

<footer class="border-t border-slate-200 bg-white py-10 dark:border-slate-800 dark:bg-slate-900">
  <div class="container-pad grid gap-8 md:grid-cols-[1.5fr_1fr]">
    <div>
      <p class="text-lg font-bold">{site.name}</p>
      <p class="mt-2 max-w-2xl text-sm leading-7 text-slate-600 dark:text-slate-300">{site.description}</p>
    </div>
    <div class="grid grid-cols-2 gap-2 text-sm">
      {navigation.map((item) => <a class="rounded-md py-1 text-slate-600 hover:text-slate-950 dark:text-slate-300 dark:hover:text-white" href={item.href}>{item.label}</a>)}
      {socialLinks.map((item) => <a class="rounded-md py-1 text-slate-600 hover:text-slate-950 dark:text-slate-300 dark:hover:text-white" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}>{item.label}</a>)}
    </div>
  </div>
</footer>
