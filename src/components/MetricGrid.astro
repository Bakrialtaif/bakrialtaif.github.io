---
import { CalendarCheck, Database, Landmark, Network, ShieldCheck, Workflow } from "lucide-astro";
import type { MetricItem } from "@/data/site/types";
import type { Locale } from "@/i18n";

type Labels = {
  details: string;
  fields: {
    role: string;
  };
};
type Props = { metrics: MetricItem[]; locale?: Locale; labels: Labels };
const { metrics, locale = "ar", labels } = Astro.props;

const visualIcons = {
  notifications: Workflow,
  platform: Network,
  security: ShieldCheck,
  calendar: CalendarCheck,
  data: Database,
  erp: Landmark
};

const renderDescription = (description: string, metricValues: string[]) => {
  const parts: { text: string; metric?: boolean }[] = [];
  const pattern = /\{(\d+)\}/g;
  let lastIndex = 0;
  let match: RegExpExecArray | null;

  while ((match = pattern.exec(description)) !== null) {
    if (match.index > lastIndex) {
      parts.push({ text: description.slice(lastIndex, match.index) });
    }

    parts.push({ text: metricValues[Number(match[1])] ?? match[0], metric: true });
    lastIndex = pattern.lastIndex;
  }

  if (lastIndex < description.length) {
    parts.push({ text: description.slice(lastIndex) });
  }

  return parts;
};
---

<div class="grid gap-5 lg:grid-cols-2">
  {metrics.map((project) => {
    const VisualIcon = visualIcons[project.visual] ?? Network;
    return (
      <article class="surface group flex min-h-72 flex-col overflow-hidden rounded-lg transition duration-200 hover:-translate-y-0.5 hover:shadow-lg">
        <div class="border-b border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-900/70">
          <div class="flex items-start gap-4">
            <div class="grid h-12 w-12 shrink-0 place-items-center rounded-lg bg-white text-teal shadow-sm dark:bg-slate-800 dark:text-teal-300">
              <VisualIcon class="h-6 w-6" aria-hidden="true" />
            </div>
            <div class="min-w-0">
              <h3 class="text-xl font-bold leading-8 text-slate-950 dark:text-white">{project.title}</h3>
              <p class="mt-1 text-sm font-semibold leading-7 text-copper dark:text-amber-300">{project.organization}</p>
            </div>
          </div>
          <div class="mt-5 grid grid-cols-4 gap-1" aria-hidden="true">
            <span class="h-1.5 rounded bg-teal"></span>
            <span class="h-1.5 rounded bg-river"></span>
            <span class="h-1.5 rounded bg-copper"></span>
            <span class="h-1.5 rounded bg-slate-300 dark:bg-slate-700"></span>
          </div>
        </div>

        <div class="flex flex-1 flex-col p-6">
          <p class="text-base leading-9 text-slate-700 dark:text-slate-200">
            {renderDescription(project.description, project.metrics).map((part) => (
              part.metric
                ? <strong class="inline-block font-latin text-lg font-bold text-teal [unicode-bidi:isolate] dark:text-teal-300" dir={locale === "ar" ? "rtl" : "ltr"}>{part.text}</strong>
                : <span>{part.text}</span>
            ))}
          </p>

          <div class="mt-auto pt-6">
            <div>
              <p class="text-xs font-bold text-slate-500 dark:text-slate-400">{labels.fields.role}</p>
              <p class="mt-1 text-sm font-semibold leading-7 text-copper dark:text-amber-300">{project.role}</p>
            </div>
          </div>
        </div>
      </article>
    );
  })}
</div>
