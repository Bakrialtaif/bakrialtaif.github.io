---
type Metric = { value: string; label: string };
type Props = { metrics: Metric[] };
const { metrics } = Astro.props;
---

<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
  {metrics.map((metric) => (
    <div class="surface rounded-lg p-5">
      <p class="font-latin text-3xl font-bold text-slate-950 dark:text-white" dir="ltr">{metric.value}</p>
      <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{metric.label}</p>
    </div>
  ))}
</div>
