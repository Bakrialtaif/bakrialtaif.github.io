---
type Props = { eyebrow: string; title: string; description: string };
const { eyebrow, title, description } = Astro.props;
---

<section class="border-b border-slate-200 bg-white py-14 dark:border-slate-800 dark:bg-slate-900">
  <div class="container-pad">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="mt-3 max-w-4xl text-4xl font-bold leading-tight text-slate-950 sm:text-5xl dark:text-white">{title}</h1>
    <p class="mt-5 max-w-3xl text-lg leading-9 text-slate-600 dark:text-slate-300">{description}</p>
  </div>
</section>
