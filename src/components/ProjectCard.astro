---
import { ArrowLeft, Building2, CalendarCheck, Database, Landmark, Network, ShieldCheck, Workflow } from "lucide-astro";
import type { Project } from "@/data/projects";
type Props = { project: Project };
const { project } = Astro.props;
const visualIcons = {
  notifications: Workflow,
  platform: Network,
  security: ShieldCheck,
  calendar: CalendarCheck,
  data: Database,
  erp: Landmark
};
const VisualIcon = visualIcons[project.visual] ?? Network;
---

<article class="surface flex h-full flex-col overflow-hidden rounded-lg">
  <div class="border-b border-slate-200 bg-slate-50 p-5 dark:border-slate-800 dark:bg-slate-900/70">
    <div class="flex items-center justify-between gap-4">
      <div class="grid h-14 w-14 place-items-center rounded-lg bg-white text-teal shadow-sm dark:bg-slate-800 dark:text-teal-300">
        <VisualIcon class="h-7 w-7" aria-hidden="true" />
      </div>
      <span class="rounded-md bg-white px-2.5 py-1 text-xs font-bold text-slate-600 dark:bg-slate-800 dark:text-slate-300">{project.type}</span>
    </div>
    <div class="mt-5 grid grid-cols-4 gap-1" aria-hidden="true">
      <span class="h-1.5 rounded bg-teal"></span>
      <span class="h-1.5 rounded bg-river"></span>
      <span class="h-1.5 rounded bg-copper"></span>
      <span class="h-1.5 rounded bg-slate-300 dark:bg-slate-700"></span>
    </div>
  </div>
  <div class="flex flex-1 flex-col p-5">
  <div class="flex items-center gap-2 text-sm text-teal dark:text-teal-300">
    <Building2 class="h-4 w-4" aria-hidden="true" />
    <span>{project.organization}</span>
  </div>
  <h3 class="mt-3 text-xl font-bold leading-8 text-slate-950 dark:text-white">{project.name}</h3>
  <p class="mt-2 text-sm font-semibold text-copper dark:text-amber-300">{project.role}</p>
  <p class="mt-3 flex-1 text-sm leading-7 text-slate-600 dark:text-slate-300">{project.objective}</p>
  <div class="mt-4">
    <p class="text-xs font-bold uppercase tracking-wide text-slate-500 dark:text-slate-400">Business Impact</p>
    <p class="mt-2 text-sm leading-7 text-slate-700 dark:text-slate-200">{project.businessImpact.impact}</p>
  </div>
  <div class="mt-4 flex flex-wrap gap-2">
    {project.technologies.slice(0, 4).map((tech) => <span class="rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700 dark:bg-slate-800 dark:text-slate-200">{tech}</span>)}
  </div>
  <a href={`/projects/${project.slug}`} class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-river dark:text-blue-300">
    دراسة الحالة
    <ArrowLeft class="h-4 w-4" aria-hidden="true" />
  </a>
  </div>
</article>
