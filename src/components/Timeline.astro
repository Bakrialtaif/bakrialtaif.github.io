---
import type { Locale } from "@/i18n";
type ExperienceItem = {
  title: string;
  organization: string;
  country: string;
  period: string;
  endDate?: string;
  focus?: string;
  highlight?: string;
  summary?: string;
  responsibilities: string[];
  tags?: string[];
};
type Props = { experience: ExperienceItem[]; locale?: Locale };
const { experience, locale = "ar" } = Astro.props;

const tagStyles = [
  "bg-teal/10 text-teal ring-teal/20 dark:bg-teal/15 dark:text-teal-200 dark:ring-teal/30",
  "bg-river/10 text-river ring-river/20 dark:bg-river/15 dark:text-blue-200 dark:ring-river/30",
  "bg-copper/10 text-copper ring-copper/20 dark:bg-copper/15 dark:text-amber-200 dark:ring-copper/30",
  "bg-rose-100 text-rose-700 ring-rose-200 dark:bg-rose-500/15 dark:text-rose-200 dark:ring-rose-400/30",
  "bg-emerald-100 text-emerald-700 ring-emerald-200 dark:bg-emerald-500/15 dark:text-emerald-200 dark:ring-emerald-400/30",
  "bg-violet-100 text-violet-700 ring-violet-200 dark:bg-violet-500/15 dark:text-violet-200 dark:ring-violet-400/30"
];
---

<ol class:list={["relative grid gap-5 border-slate-200 dark:border-slate-800", locale === "ar" ? "border-r pr-5" : "border-l pl-5"]}>
  {experience.map((item) => (
    <li class="relative">
      <span class:list={["absolute top-1 h-4 w-4 rounded-full border-4 border-paper bg-teal dark:border-slate-950", locale === "ar" ? "-right-[29px]" : "-left-[29px]"]}></span>
      <div class="surface rounded-lg p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <h3 class="text-xl font-bold leading-8 text-slate-950 dark:text-white">{item.title}</h3>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">{item.organization} - {item.country}</p>
          </div>
          <p class="shrink-0 rounded-md bg-slate-100 px-3 py-1.5 text-sm font-bold text-copper dark:bg-slate-800 dark:text-amber-300">{item.endDate ?? item.period}</p>
        </div>
        {item.summary && <p class="mt-4 max-w-3xl text-sm leading-8 text-slate-600 dark:text-slate-300">{item.summary}</p>}
        {item.tags && (
          <div class="mt-4 flex flex-wrap gap-2">
            {item.tags.map((tag, index) => <span class:list={["rounded-md px-2.5 py-1 text-xs font-bold ring-1", tagStyles[index % tagStyles.length]]}>{tag}</span>)}
          </div>
        )}
      </div>
    </li>
  ))}
</ol>
