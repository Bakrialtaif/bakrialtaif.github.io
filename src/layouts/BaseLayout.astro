---
import "../styles/global.css";
import Navigation from "@/components/Navigation.astro";
import Footer from "@/components/Footer.astro";
import ProfessionalContactSection from "@/components/ProfessionalContactSection.astro";
import GoogleAnalytics from "@/components/analytics/GoogleAnalytics.astro";
import ContextualContactPrompt from "@/components/contact/ContextualContactPrompt.astro";
import FloatingContactButton from "@/components/contact/FloatingContactButton.astro";
import { alternateLocalePath, getContent, getDir, localizePath, type Locale } from "@/i18n";

type Props = {
  title: string;
  description: string;
  locale?: Locale;
  canonical?: string;
  robots?: string;
};

const { title, description, locale = "ar", canonical = Astro.url.pathname, robots } = Astro.props;
const { site } = getContent(locale);
const pageTitle = title === site.name ? `${site.name} | ${site.role}` : `${title} | ${site.name}`;
const canonicalUrl = new URL(canonical, Astro.site).toString();
const imageUrl = new URL("/images/profile.jpeg", Astro.site).toString();
const alternateLocale = locale === "ar" ? "en" : "ar";
const alternateUrl = new URL(alternateLocalePath(Astro.url.pathname, locale), Astro.site).toString();
const defaultLocaleUrl = new URL(localizePath(Astro.url.pathname, "ar"), Astro.site).toString();
const keywords = locale === "ar"
  ? [
      "مبرمج",
      "مطور برمجيات",
      "مطور أنظمة",
      "أنظمة مؤسسية",
      "تطوير الأنظمة المؤسسية",
      "بناء الأنظمة",
      "المنتجات الرقمية",
      "برمجة تطبيقات الويب",
      "التحول الرقمي",
      "استشارات التحول الرقمي",
      "تحليل الأعمال",
      "إعادة هندسة العمليات",
      "تكامل الأنظمة",
      "قواعد البيانات",
      "نظم المعلومات",
      "لوحات المعلومات",
      "مؤشرات الأداء"
    ]
  : [
      "Product Architect",
      "Digital Transformation Lead",
      "Enterprise Systems Architect",
      "Digital Product Architecture",
      "Enterprise Systems",
      "Product Engineering",
      "Business Process Reengineering",
      "Technical Leadership",
      "Systems Design",
      "Digital Transformation"
    ];
---

<!doctype html>
<html lang={locale} dir={getDir(locale)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="keywords" content={keywords.join(", ")} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLocale} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={defaultLocaleUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === "ar" ? "ar_SD" : "en_US"} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <GoogleAnalytics />
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (savedTheme === "dark" || (!savedTheme && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: site.name,
      alternateName: site.nameEn,
      jobTitle: site.role,
      url: site.website,
      nationality: "Sudanese",
      image: imageUrl,
      email: site.email,
      sameAs: [site.linkedin, site.github, site.website],
      knowsLanguage: ["ar", "en"],
      knowsAbout: keywords
    })} />
  </head>
  <body>
    <Navigation locale={locale} />
    <main id="main-content">
      <slot />
    </main>
    <ProfessionalContactSection locale={locale} />
    <ContextualContactPrompt locale={locale} pathname={Astro.url.pathname} />
    <FloatingContactButton locale={locale} />
    <Footer locale={locale} />
  </body>
</html>
