---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import { getContent, type Locale } from "@/i18n";
import { educationPageContent } from "@/i18n/educationPage";

type Props = { locale: Locale };
const { locale } = Astro.props;
const content = getContent(locale);
const page = content.pages.education;
const educationPage = educationPageContent[locale];
const academicItems = content.education.filter((item) => item.category !== "course");
const courseItems = content.education.filter((item) => item.category === "course");
---

<BaseLayout locale={locale} title={page.title} description={page.description}>
  <section class="container-pad py-14" data-analytics-section="education" data-analytics-view-event="education_section_view">
    <SectionTitle eyebrow={educationPage.eyebrow} title={educationPage.title} description={educationPage.description} />
  </section>

  <section class="container-pad pb-14">
    <SectionTitle title={educationPage.academicTitle} />
    <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {academicItems.map((item) => (
        <article class:list={["surface relative rounded-lg p-5", item.document && "pl-24"]}>
          {item.document && (
            <a href={item.document} target="_blank" rel="noreferrer" class="absolute left-4 top-4 block overflow-hidden rounded-md ring-1 ring-slate-200 transition hover:-translate-y-0.5 hover:ring-river dark:ring-slate-700" aria-label={item.title}>
              <img src={item.document} alt={item.title} class="h-16 w-16 bg-slate-100 object-cover object-top dark:bg-slate-800" loading="lazy" />
            </a>
          )}
          <p class="text-sm font-semibold text-copper dark:text-amber-300">{item.date}</p>
          <h2 class="mt-2 text-xl font-bold">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{item.institution}</p>
          <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{item.meta}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white py-14 dark:border-slate-800 dark:bg-slate-900">
    <div class="container-pad">
      <SectionTitle title={educationPage.coursesTitle} />
      <div class="mt-8 grid gap-5 md:grid-cols-2">
        {courseItems.map((item) => (
          <article class:list={["surface relative rounded-lg p-5", item.document && "pl-24"]}>
            {item.document && (
              <a href={item.document} target="_blank" rel="noreferrer" class="absolute left-4 top-4 block overflow-hidden rounded-md ring-1 ring-slate-200 transition hover:-translate-y-0.5 hover:ring-river dark:ring-slate-700" aria-label={item.title}>
                <img src={item.document} alt={item.title} class="h-16 w-16 bg-slate-100 object-cover object-top dark:bg-slate-800" loading="lazy" />
              </a>
            )}
            <p class="text-sm font-semibold text-copper dark:text-amber-300">{item.date}</p>
            <h2 class="mt-2 text-xl font-bold">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{item.institution}</p>
            <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{item.meta}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container-pad py-14">
    <SectionTitle title={educationPage.skillsTitle} />
    <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {educationPage.skillGroups.map((group) => (
        <article class="surface rounded-lg p-5">
          <h2 class="text-xl font-bold">{group.title}</h2>
          <div class="mt-5 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="rounded-full border border-slate-200 px-3 py-1 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:text-slate-200">
                {item}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
