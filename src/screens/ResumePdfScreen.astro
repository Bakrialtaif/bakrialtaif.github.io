---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { getContent, type Locale } from "@/i18n";

type Props = { locale: Locale };
const { locale } = Astro.props;
const content = getContent(locale);
const { site, pages, ui } = content;
const page = pages.resumePdf;
---

<BaseLayout locale={locale} title={page.title} description={page.description}>
  <PageHero eyebrow={page.title} title={page.heroTitle} description={page.heroDescription} />
  <section class="container-pad py-14">
    <a href={site.resumePdf} class="inline-flex rounded-md bg-slate-950 px-5 py-3 text-sm font-bold text-white dark:bg-white dark:text-slate-950" data-analytics-event="cv_download" data-analytics-location="resume_pdf_page">{ui.downloadFile}</a>
  </section>
</BaseLayout>
