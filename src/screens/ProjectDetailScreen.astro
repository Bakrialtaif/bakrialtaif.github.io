---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { getContent, type Locale } from "@/i18n";
import type { Project } from "@/data/projects";

type Props = { locale: Locale; project: Project };
const { locale, project } = Astro.props;
const { ui } = getContent(locale);
---

<BaseLayout locale={locale} title={project.name} description={project.summary}>
  <PageHero eyebrow={project.type} title={project.name} description={project.summary} />
  <section class="container-pad grid gap-8 py-14 lg:grid-cols-[0.75fr_1.25fr]">
    <aside class="surface h-fit rounded-lg p-5">
      <dl class="grid gap-4 text-sm">
        <div>
          <dt class="font-bold text-slate-950 dark:text-white">{ui.fields.organization}</dt>
          <dd class="mt-1 text-slate-600 dark:text-slate-300">{project.organization}</dd>
        </div>
        <div>
          <dt class="font-bold text-slate-950 dark:text-white">{ui.fields.role}</dt>
          <dd class="mt-1 text-slate-600 dark:text-slate-300">{project.role}</dd>
        </div>
        <div>
          <dt class="font-bold text-slate-950 dark:text-white">{ui.fields.period}</dt>
          <dd class="mt-1 text-slate-600 dark:text-slate-300">{project.period}</dd>
        </div>
        {project.link && <a class="font-bold text-river dark:text-blue-300" href={project.link}>{ui.fields.projectLink}</a>}
      </dl>
    </aside>
    <div class="grid gap-6">
      <section class="surface rounded-lg p-6">
        <h2 class="text-2xl font-bold">{ui.fields.projectOverview}</h2>
        <p class="mt-3 leading-8 text-slate-700 dark:text-slate-200">{project.overview}</p>
      </section>
      <section class="surface rounded-lg p-6">
        <h2 class="text-2xl font-bold">{ui.fields.role}</h2>
        <ul class="mt-4 grid gap-2 leading-8 text-slate-700 dark:text-slate-200">
          {project.responsibilities.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section class="surface rounded-lg p-6">
        <h2 class="text-2xl font-bold">{ui.fields.technologies}</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {project.technologies.map((tech) => <span class="rounded-md bg-slate-100 px-3 py-1.5 text-sm font-bold dark:bg-slate-800">{tech}</span>)}
        </div>
      </section>
      <section class="surface rounded-lg p-6">
        <h2 class="text-2xl font-bold">{ui.fields.keyFeatures}</h2>
        <div class="mt-4 grid gap-2 sm:grid-cols-2">
          {project.keyFeatures.map((item) => <span class="rounded-md bg-slate-100 px-3 py-2 text-sm font-semibold dark:bg-slate-800">{item}</span>)}
        </div>
      </section>
      <section class="surface rounded-lg p-6">
        <h2 class="text-2xl font-bold">{ui.fields.businessImpact}</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-3">
          <div>
            <h3 class="font-bold text-copper dark:text-amber-300">{ui.fields.problem}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700 dark:text-slate-200">{project.businessImpact.problem}</p>
          </div>
          <div>
            <h3 class="font-bold text-copper dark:text-amber-300">{ui.fields.solution}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700 dark:text-slate-200">{project.businessImpact.solution}</p>
          </div>
          <div>
            <h3 class="font-bold text-copper dark:text-amber-300">{ui.fields.impact}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-700 dark:text-slate-200">{project.businessImpact.impact}</p>
          </div>
        </div>
      </section>
      <section class="surface rounded-lg p-6">
        <h2 class="text-2xl font-bold">{ui.fields.results}</h2>
        <ul class="mt-4 grid gap-2 leading-8 text-slate-700 dark:text-slate-200">
          {project.results.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    </div>
  </section>
</BaseLayout>
