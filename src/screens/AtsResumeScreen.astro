---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import { getContent, type Locale } from "@/i18n";

type Props = { locale: Locale };
const { locale } = Astro.props;
const content = getContent(locale);
const { site, pages } = content;
const page = pages.ats;
---

<BaseLayout locale={locale} title={page.title} description={page.description}>
  <PageHero eyebrow={page.title} title={site.name} description={`${site.role} - ${site.description}`} />
  <section class="container-pad grid gap-10 py-14">
    <section>
      <h2 class="text-2xl font-bold">{page.impact}</h2>
      <ul class="mt-4 grid gap-2 leading-8">
        {content.impactMetrics.map((metric) => <li>{metric.value}: {metric.label}</li>)}
      </ul>
    </section>
    <section>
      <h2 class="text-2xl font-bold">{page.experience}</h2>
      <div class="mt-4 grid gap-5">
        {content.experience.map((item) => (
          <article>
            <h3 class="font-bold">{item.title} - {item.organization}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">{item.period} | {item.country}</p>
            <ul class="mt-2 grid gap-1 text-sm leading-7">
              {item.responsibilities.map((r) => <li>{r}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>
    <section>
      <h2 class="text-2xl font-bold">{page.projects}</h2>
      <div class="mt-4 grid gap-5">
        {content.projects.map((project) => (
          <article>
            <h3 class="font-bold">{project.name}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300">{project.organization} | {project.role}</p>
            <p class="mt-2 text-sm leading-7">{project.summary}</p>
          </article>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
