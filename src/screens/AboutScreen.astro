---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import { aboutLessons } from "@/i18n/aboutLessons";
import { aboutProfile } from "@/i18n/aboutProfile";
import { getContent, type Locale } from "@/i18n";

type Props = { locale: Locale };
const { locale } = Astro.props;
const content = getContent(locale);
const { pages } = content;
const page = pages.about;
const profile = aboutProfile[locale];
const lessons = aboutLessons[locale];
---

<BaseLayout locale={locale} title={profile.introTitle} description={page.description}>
  <section class="container-pad py-14" data-analytics-section="experience" data-analytics-view-event="experience_section_view">
    <div class="grid gap-8 lg:grid-cols-[1.35fr_0.65fr]">
      <div>
        <p class="eyebrow">{page.title}</p>
        <h1 class="mt-2 text-3xl font-bold leading-tight text-slate-950 sm:text-4xl dark:text-white">{profile.introTitle}</h1>
        <p class="mt-5 text-lg leading-10 text-slate-700 dark:text-slate-200">{profile.introText}</p>
      </div>
      <aside class="surface rounded-lg p-5">
        <h2 class="text-xl font-bold text-slate-950 dark:text-white">{profile.stationsTitle}</h2>
        <div class="mt-4 grid gap-2 text-sm font-semibold leading-7 text-slate-600 dark:text-slate-300">
          {profile.stations.map((station) => <p>{station}</p>)}
        </div>
      </aside>
    </div>
  </section>

  <section class="container-pad py-14">
    <SectionTitle eyebrow={profile.journeyEyebrow} title={profile.journeyTitle} />
    <ol class:list={["mt-8 grid gap-5 border-slate-200 dark:border-slate-800", locale === "ar" ? "border-r pr-5" : "border-l pl-5"]}>
      {profile.journey.map((item) => (
        <li class="relative">
          <span class:list={["absolute top-2 h-3.5 w-3.5 rounded-full border-4 border-paper bg-teal dark:border-slate-950", locale === "ar" ? "-right-[27px]" : "-left-[27px]"]}></span>
          <article class="surface rounded-lg p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <h2 class="text-xl font-bold">{item.title}</h2>
              <p class="rounded-md bg-slate-100 px-3 py-1.5 text-sm font-bold text-copper dark:bg-slate-800 dark:text-amber-300">{item.period}</p>
            </div>
            <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{item.text}</p>
            <p class="mt-3 rounded-md bg-slate-50 px-3 py-2 text-sm font-semibold leading-7 text-teal dark:bg-slate-800 dark:text-teal-300">{item.note}</p>
          </article>
        </li>
      ))}
    </ol>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="container-pad">
      <SectionTitle eyebrow={profile.sectorsEyebrow} title={profile.sectorsTitle} />
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-5">
        {profile.sectors.map(([title, text]) => (
          <article class="surface rounded-lg p-5">
            <h2 class="text-xl font-bold">{title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container-pad py-14">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionTitle eyebrow={profile.projectTypesEyebrow} title={profile.projectTypesTitle} description={profile.projectTypesDescription} />
      <div class="flex flex-wrap gap-3">
        {profile.projectTypes.map((type) => (
          <span class="rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-100">{type}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="container-pad">
      <SectionTitle eyebrow={profile.expertiseEyebrow} title={profile.expertiseTitle} description={profile.expertiseDescription} />
      <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {content.expertise.map((group) => (
          <article class="surface rounded-lg p-5">
            <h2 class="text-xl font-bold">{group.title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{group.summary}</p>
            <p class="mt-3 text-sm font-semibold leading-7 text-teal dark:text-teal-300">{group.proof}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {group.items.map((item) => <span class="rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold dark:bg-slate-800">{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container-pad py-14">
    <SectionTitle eyebrow={lessons.eyebrow} title={lessons.title} description={lessons.description} />
    <div class="mt-8 grid gap-5 md:grid-cols-5">
      {lessons.items.map(([title, text]) => (
        <article class="surface rounded-lg p-5">
          <h2 class="text-xl font-bold">{title}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="container-pad">
      <SectionTitle eyebrow={profile.toolsEyebrow} title={profile.toolsTitle} />
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {content.skillGroups.map((group) => (
          <article class="surface rounded-lg p-5">
            <h2 class="text-lg font-bold">{group.title}</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {group.items.map((item) => <span class="rounded-md bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-700 dark:bg-slate-800 dark:text-slate-100">{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
