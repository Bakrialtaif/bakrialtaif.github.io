---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import { getContent, type Locale } from "@/i18n";

type Props = { locale: Locale };
const { locale } = Astro.props;
const { pages } = getContent(locale);
const page = pages.about;
const workMethods = page.workMethods ?? page.capabilities;
const fields = page.fields ?? [];
const successMeasures = page.successMeasures ?? [];
---

<BaseLayout locale={locale} title={page.title} description={page.description}>
  <PageHero eyebrow={page.title} title={page.heroTitle} description={page.heroDescription} />
  <section class="container-pad py-14">
    <div class="max-w-4xl text-lg leading-10 text-slate-700 dark:text-slate-200">
      <p>{page.intro ?? page.body1}</p>
    </div>
  </section>
  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="container-pad">
      <SectionTitle eyebrow={page.workEyebrow ?? page.capabilitiesEyebrow} title={page.workTitle ?? page.capabilitiesTitle} />
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {workMethods.map(([title, text]) => (
          <article class="surface rounded-lg p-5">
            <h2 class="text-xl font-bold">{title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="container-pad py-14">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionTitle eyebrow={page.fieldsEyebrow} title={page.fieldsTitle} />
      <div class="flex flex-wrap gap-3">
        {fields.map((field) => (
          <span class="rounded-md bg-slate-100 px-3 py-2 text-sm font-bold text-slate-700 ring-1 ring-slate-200 dark:bg-slate-800 dark:text-slate-100 dark:ring-slate-700">{field}</span>
        ))}
      </div>
    </div>
  </section>
  <section class="bg-white py-14 dark:bg-slate-900">
    <div class="container-pad grid gap-8 lg:grid-cols-2">
      <article>
        <SectionTitle eyebrow={page.enjoyEyebrow} title={page.enjoyTitle} description={page.enjoyText} />
      </article>
      <article>
        <SectionTitle eyebrow={page.outsideEyebrow} title={page.outsideTitle} description={page.outsideText} />
      </article>
    </div>
  </section>
  <section class="container-pad py-14">
    <SectionTitle eyebrow={page.successEyebrow} title={page.successTitle} />
    <div class="mt-8 grid gap-5 md:grid-cols-4">
      {successMeasures.map(([title, text]) => (
        <article class="surface rounded-lg p-5">
          <h2 class="text-lg font-bold text-teal dark:text-teal-300">{title}</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">{text}</p>
        </article>
      ))}
    </div>
  </section>
  <section class="bg-slate-950 py-14 text-white dark:bg-black">
    <div class="container-pad">
      <p class="max-w-4xl text-xl font-semibold leading-10 text-slate-100">{page.closingText}</p>
    </div>
  </section>
</BaseLayout>
